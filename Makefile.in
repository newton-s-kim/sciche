BUILD_DIR=@__build_dir__@
PROGRAMME=sciche

all:
	$(MAKE) -C $(BUILD_DIR) -j`nproc`

clean:
	$(MAKE) -C $(BUILD_DIR) clean/fast

run:
	$(BUILD_DIR)/$(PROGRAMME)

tc:
	./tool/run-test.py

bm:
	./tool/benchmark.py > benchmark-`git branch --show-current`-`date +%y%m%d-%H%M%S`.txt

prof:
	for f in `find test/wren/benchmark/ -name "*.wren"`; do ./profile.sh $$f; done

distclean:
	rm Makefile
	rm byte-code/src/common.hpp
	rm byte-code/src/dictionary.hpp
	rm byte-code/src/members.dct
	rm -rf $(BUILD_DIR)
	find test -name "*.gmon" -exec rm {} \;
	find test -name "*.png" -exec rm {} \;
